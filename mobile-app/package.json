{
  "name": "ml-on-the-go",
  "version": "1.0.0",
  "description": "ML on the Go - Mobile App for Financial Risk Analytics",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Build complete'",
    "cap:init": "npx cap init 'ML on the Go' com.mlotg.app --web-dir www",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "android:build:debug": "cd android && ./gradlew assembleDebug",
    "android:build:release": "cd android && ./gradlew assembleRelease",
    "android:build:bundle": "cd android && ./gradlew bundleRelease"
  },
  "keywords": ["ml", "machine-learning", "finance", "risk-analytics", "android"],
  "author": "ML Team",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/core": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0"
  }
}
